+    transform: rotate(0deg);
+  }
+
+  100% {
+    transform: rotate(360deg);
+  }
+}
+
+@keyframes dock-bubble-float {
+  0% {
+    transform: translate3d(-50%, 0, 0) scale(1);
+    opacity: 0.82;
+  }
+
+  50% {
+    transform: translate3d(-50%, -3px, 0) scale(1.03);
+    opacity: 1;
+  }
+
+  100% {
+    transform: translate3d(-50%, 0, 0) scale(1);
+    opacity: 0.82;
+  }
+}
+
+@keyframes bubble-background-float {
+  0% {
+    transform: translate3d(0, 0, 0) scale(0.96);
+    opacity: 0.4;
+  }
+
+  25% {
+    transform: translate3d(10px, -12px, 0) scale(1);
+    opacity: 0.58;
+  }
+
+  50% {
+    transform: translate3d(-8px, -20px, 0) scale(1.05);
+    opacity: 0.72;
+  }
+
+  75% {
+    transform: translate3d(12px, -8px, 0) scale(1.01);
+    opacity: 0.54;
+  }
+
+  100% {
+    transform: translate3d(0, 0, 0) scale(0.96);
+    opacity: 0.4;
+  }
+}
+
+@keyframes bubble-background-image-drift {
+  0% {
+    transform: scale(1.05) translate3d(0, 0, 0);
+    opacity: 0.68;
+  }
+
+  50% {
+    transform: scale(1.09) translate3d(1.5%, -1%, 0);
+    opacity: 0.8;
+  }
+
+  100% {
+    transform: scale(1.12) translate3d(-1%, 1.5%, 0);
+    opacity: 0.72;
+  }
+}
+
+.magic-border-beam {
+  animation-name: magic-border-beam-spin;
+  animation-duration: var(--beam-duration, 8s);
+  animation-delay: var(--beam-delay, 0s);
+  animation-iteration-count: infinite;
+  animation-timing-function: linear;
+  animation-direction: var(--beam-direction, normal);
+  will-change: transform;
+}
+
+.animate-aurora {
+  animation: aurora 8s ease-in-out infinite alternate;
+  will-change: background-position, transform;
+}
+
 @media (prefers-reduced-motion: reduce) {
   .project-light-ray {
     animation: none;
   }
+
+  .featured-badge-animated,
+  .featured-badge-animated::after,
+  .dock-bubble-label,
+  .bubble-background-image,
+  .bubble-background-orb,
+  .magic-border-beam,
+  .gold-spotlight-card::before,
+  .gold-spotlight-card::after {
+    animation: none;
+  }
+}
+
+@keyframes aurora {
+  0% {
+    background-position: 0% 50%;
+  }
+
+  25% {
+    background-position: 50% 100%;
+  }
+
+  50% {
+    background-position: 100% 50%;
+  }
+
+  75% {
+    background-position: 50% 0%;
+  }
+
+  100% {
+    background-position: 0% 50%;
+  }
 }
